# -------------------------------------------------------
# sync-service environment variable reference
#
# PURPOSE: Documents every env var the sync service reads.
#   Copy this file to .env.local for local development.
#
# IMPORTANT — NEVER put real secrets in this file or any .env file.
#   Real secrets (Figma token, DB password, API key, webhook passcode)
#   live in AWS Secrets Manager in production.
#   In local dev (LOCAL_DEV=true), they are read from env vars set in
#   your .env.local file, which is git-ignored.
#
# SAM / LOCAL LAMBDA NOTE:
#   This file covers env vars for direct Node.js execution (e.g. ts-node).
#   Running handlers via AWS SAM CLI (sam local invoke) additionally requires
#   a template.yaml that is not yet implemented in this repo.
#   Until template.yaml exists, run handlers directly with ts-node or
#   use the unit test suite for local verification.
# -------------------------------------------------------

# AWS region where resources are deployed
AWS_REGION=us-east-1

# Name of the Secrets Manager secret containing all runtime secrets.
# Secret value must be a JSON object with the keys below.
# {
#   "figmaServiceToken": "...",
#   "dbConnectionString": "postgres://...",
#   "syncServiceApiKey": "...",
#   "figmaWebhookPasscode": "..."
# }
SECRETS_MANAGER_SECRET_NAME=figma-jira/sync-service

# S3 bucket for cached thumbnails
THUMBNAIL_BUCKET_NAME=figma-jira-thumbnails-dev

# Polling interval in minutes (used by polling-sync EventBridge rule)
POLLING_INTERVAL_MINUTES=30

# Base backoff interval for failed syncs, in seconds
SYNC_BACKOFF_BASE_SECONDS=60

# Maximum backoff cap for failed syncs, in seconds (default: 4 hours)
SYNC_BACKOFF_MAX_SECONDS=14400

# -------------------------------------------------------
# LOCAL DEVELOPMENT ONLY — not used in Lambda
#
# These vars bypass AWS Secrets Manager so you can run the
# service locally without AWS credentials.
# Set LOCAL_DEV=true and fill in the values below in your
# .env.local file. DO NOT commit .env.local.
# -------------------------------------------------------

LOCAL_DEV=true

# Figma service token — leave blank here; set a real token only in .env.local
FIGMA_SERVICE_TOKEN=

# Local Postgres connection string — dev default only, CHANGE for your setup
DB_CONNECTION_STRING=postgres://postgres:postgres@localhost:5432/figma_jira

# Shared API key between Jira plugin and sync service
# EXAMPLE VALUE ONLY — must be changed before any non-local use
SYNC_SERVICE_API_KEY=dev-api-key-change-in-production

# Figma webhook passcode — validated on every incoming webhook event
# EXAMPLE VALUE ONLY — must be changed before any non-local use
FIGMA_WEBHOOK_PASSCODE=dev-webhook-passcode-change-in-production
