{
  "name": "@figma-jira/sync-service",
  "version": "0.0.1",
  "private": true,
  "description": "AWS Lambda sync service — Figma API integration, webhooks, sync jobs",
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "migrate": "node --loader ts-node/esm src/db/migrate.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.614.0",
    "@aws-sdk/client-secrets-manager": "^3.614.0",
    "@aws-sdk/s3-request-presigner": "^3.614.0",
    "@figma-jira/shared-types": "workspace:*",
    "kysely": "^0.27.3",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/aws-lambda": "^8.10.143",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [".ts"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true,
          "isolatedModules": true
        }
      ]
    },
    "testMatch": ["**/__tests__/**/*.test.ts"]
  }
}
